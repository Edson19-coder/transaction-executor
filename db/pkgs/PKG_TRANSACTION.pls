CREATE OR REPLACE PACKAGE PKG_TRANSACTION AS TYPE CursorType IS REF CURSOR;
    PROCEDURE ADD_TRANSACTION(pId IN VARCHAR2, pAccountId IN VARCHAR2, pType IN VARCHAR2, pAmount IN NUMBER, pCurrency IN VARCHAR2,
    pDescription IN VARCHAR2, pStatus IN VARCHAR2, pProviderTransactionId IN VARCHAR2, pBalanceAfter IN NUMBER, pCreatedAt IN VARCHAR, oResult OUT VARCHAR2);
    PROCEDURE GET_TRANSACTION(pAccountId IN VARCHAR2, pStatus IN VARCHAR2, pType IN VARCHAR2, pPage IN NUMBER, pLimit IN NUMBER, rc OUT SYS_REFCURSOR);
    PROCEDURE GET_TRANSACTION_COUNT(pAccountId IN VARCHAR2, pStatus IN VARCHAR2, pType IN VARCHAR2, oCount OUT NUMBER);
END PKG_TRANSACTION;
